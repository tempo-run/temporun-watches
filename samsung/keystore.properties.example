# Modelo de credenciais de assinatura de release.
#
# 1. Copie este arquivo para "keystore.properties" (mesmo diretório):
#       cp keystore.properties.example keystore.properties
# 2. Preencha com os dados da SUA upload key.
# 3. NUNCA versione o keystore.properties nem o .jks — ambos já estão no .gitignore.
#
# IMPORTANTE: use a MESMA upload key do app de telefone. O wear e o celular
# compartilham o applicationId com.temporun.run, então são o MESMO app na Play e
# precisam ser assinados com a mesma chave.

# Caminho absoluto do arquivo da keystore (.jks). Mantenha-o FORA do repositório.
storeFile=/Users/SEU_USUARIO/keystores/temporun-upload.jks

# Senha da keystore (store)
storePassword=

# Alias da chave dentro da keystore
keyAlias=upload

# Senha da chave (key)
keyPassword=
